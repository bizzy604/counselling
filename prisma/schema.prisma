generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  COUNSELLOR
  EMPLOYER
  ADMIN
}

enum NotificationChannel {
  EMAIL
  SMS
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum ServiceType {
  INDIVIDUAL
  FAMILY
  STRESS
  SUBSTANCE_USE
  ASSESSMENT
}

enum AppointmentStatus {
  SCHEDULED
  ATTENDED
  NO_SHOW
  CANCELLED
}

enum RequestSource {
  SELF_SERVICE
  WAITLIST
  SPECIFIC_COUNSELLOR
  EMPLOYER_REFERRAL
  CRISIS
}

enum RequestStatus {
  PENDING_APPROVAL
  ASSIGNED
  REJECTED
}

enum UrgencyLevel {
  ROUTINE
  URGENT
  CRISIS
}

enum ReferralStatus {
  SUBMITTED
  ASSIGNED
  REJECTED
}

model User {
  id                 String          @id @default(uuid()) @db.Uuid
  firstName          String          @map("first_name") @db.VarChar(100)
  lastName           String          @map("last_name") @db.VarChar(100)
  email              String          @unique @db.VarChar(255)
  passwordHash       String          @map("password_hash")
  phone              String?         @unique @db.VarChar(20)
  role               UserRole
  department         String          @db.VarChar(255)
  isActive           Boolean         @default(true) @map("is_active")
  lastLoginAt        DateTime?       @map("last_login_at") @db.Timestamptz(6)
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  clientProfile      Client?
  counsellorProfile  Counsellor?
  employerProfile    Employer?
  notifications      Notification[]
  authSessions       AuthSession[]

  @@map("users")
}

model Client {
  userId                String               @id @map("user_id") @db.Uuid
  preferredLanguage     String               @default("en") @map("preferred_language") @db.VarChar(10)
  consentMoodSharing    Boolean              @default(false) @map("consent_mood_sharing")
  consentMoodSharingAt  DateTime?            @map("consent_mood_sharing_at") @db.Timestamptz(6)
  consentFlags          Json                 @default("{}") @map("consent_flags")
  serviceHistorySummary Json                 @default("[]") @map("service_history_summary")
  emergencyContactName  String?              @map("emergency_contact_name") @db.VarChar(255)
  emergencyContactPhone String?              @map("emergency_contact_phone") @db.VarChar(20)
  onboardingCompletedAt DateTime?            @map("onboarding_completed_at") @db.Timestamptz(6)
  createdAt             DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  counsellingRequests   CounsellingRequest[]
  appointments          Appointment[]
  referrals             Referral[]           @relation("ReferralClient")

  @@map("clients")
}

model Counsellor {
  userId            String                        @id @map("user_id") @db.Uuid
  licenceNumber     String                        @unique @map("licence_number") @db.VarChar(100)
  specialisations   String[]                      @default([])
  bio               String?
  maxCaseload       Int                           @default(25) @map("max_caseload")
  isOnCall          Boolean                       @default(false) @map("is_on_call")
  createdAt         DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime                      @updatedAt @map("updated_at") @db.Timestamptz(6)
  user              User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  availabilityRules CounsellorAvailabilityRule[]
  leavePeriods      CounsellorLeavePeriod[]
  appointments      Appointment[]
  preferredRequests CounsellingRequest[]          @relation("PreferredCounsellor")
  assignedRequests  CounsellingRequest[]          @relation("AssignedCounsellor")

  @@map("counsellors")
}

model Employer {
  userId          String     @id @map("user_id") @db.Uuid
  organisation    String     @db.VarChar(255)
  departmentScope String     @map("department_scope") @db.VarChar(255)
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrals       Referral[] @relation("ReferralEmployer")

  @@map("employers")
}

model Notification {
  id        String             @id @default(uuid()) @db.Uuid
  userId    String             @map("user_id") @db.Uuid
  channel   NotificationChannel
  type      String             @db.VarChar(100)
  payload   Json               @default("{}")
  status    NotificationStatus @default(PENDING)
  sentAt    DateTime?          @map("sent_at") @db.Timestamptz(6)
  readAt    DateTime?          @map("read_at") @db.Timestamptz(6)
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("notifications")
}

model AuditLog {
  id          BigInt   @id @default(autoincrement())
  userId      String   @map("user_id") @db.Uuid
  targetTable String   @map("target_table") @db.VarChar(100)
  targetId    String   @map("target_id") @db.Uuid
  action      String   @db.VarChar(50)
  ipAddress   String?  @map("ip_address") @db.Inet
  userAgent   String?  @map("user_agent")
  metadata    Json     @default("{}")
  occurredAt  DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)

  @@index([userId, occurredAt])
  @@map("audit_log")
}

model CounsellorAvailabilityRule {
  id           String     @id @default(uuid()) @db.Uuid
  counsellorId String     @map("counsellor_id") @db.Uuid
  dayOfWeek    Int        @map("day_of_week")
  startTime    DateTime   @map("start_time") @db.Time(6)
  endTime      DateTime   @map("end_time") @db.Time(6)
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  counsellor   Counsellor @relation(fields: [counsellorId], references: [userId], onDelete: Cascade)

  @@index([counsellorId, dayOfWeek])
  @@unique([counsellorId, dayOfWeek, startTime, endTime])
  @@map("counsellor_availability_rules")
}

model CounsellorLeavePeriod {
  id           String     @id @default(uuid()) @db.Uuid
  counsellorId String     @map("counsellor_id") @db.Uuid
  startsOn     DateTime   @map("starts_on") @db.Date
  endsOn       DateTime   @map("ends_on") @db.Date
  reason       String?    @db.VarChar(255)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  counsellor   Counsellor @relation(fields: [counsellorId], references: [userId], onDelete: Cascade)

  @@index([counsellorId, startsOn, endsOn])
  @@map("counsellor_leave_periods")
}

model CounsellingRequest {
  id                    String         @id @default(uuid()) @db.Uuid
  clientId              String         @map("client_id") @db.Uuid
  serviceType           ServiceType    @map("service_type")
  source                RequestSource
  urgency               UrgencyLevel   @default(ROUTINE)
  status                RequestStatus  @default(PENDING_APPROVAL)
  preferredCounsellorId String?        @map("preferred_counsellor_id") @db.Uuid
  notes                 String?
  adminReason           String?        @map("admin_reason")
  assignedCounsellorId  String?        @map("assigned_counsellor_id") @db.Uuid
  assignedAt            DateTime?      @map("assigned_at") @db.Timestamptz(6)
  rejectedAt            DateTime?      @map("rejected_at") @db.Timestamptz(6)
  createdAt             DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  client                Client         @relation(fields: [clientId], references: [userId], onDelete: Cascade)
  preferredCounsellor   Counsellor?    @relation("PreferredCounsellor", fields: [preferredCounsellorId], references: [userId], onDelete: SetNull)
  assignedCounsellor    Counsellor?    @relation("AssignedCounsellor", fields: [assignedCounsellorId], references: [userId], onDelete: SetNull)
  appointments          Appointment[]
  referral              Referral?

  @@index([clientId, status])
  @@index([assignedCounsellorId, status])
  @@index([status, createdAt])
  @@map("counselling_requests")
}

model Appointment {
  id                   String              @id @default(uuid()) @db.Uuid
  clientId             String              @map("client_id") @db.Uuid
  counsellorId         String              @map("counsellor_id") @db.Uuid
  counsellingRequestId String?             @map("counselling_request_id") @db.Uuid
  serviceType          ServiceType         @map("service_type")
  status               AppointmentStatus   @default(SCHEDULED)
  modality             String              @default("VIDEO") @db.VarChar(20)
  scheduledAt          DateTime            @map("scheduled_at") @db.Timestamptz(6)
  cancelledAt          DateTime?           @map("cancelled_at") @db.Timestamptz(6)
  cancelledBy          String?             @map("cancelled_by") @db.Uuid
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  client               Client              @relation(fields: [clientId], references: [userId], onDelete: Cascade)
  counsellor           Counsellor          @relation(fields: [counsellorId], references: [userId], onDelete: Restrict)
  counsellingRequest   CounsellingRequest? @relation(fields: [counsellingRequestId], references: [id], onDelete: SetNull)

  @@unique([counsellorId, scheduledAt])
  @@index([clientId, scheduledAt])
  @@index([status, scheduledAt])
  @@map("appointments")
}

model AuthSession {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  refreshTokenId String    @unique @map("refresh_token_id") @db.Uuid
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz(6)
  lastSeenAt     DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  revokedAt      DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("auth_sessions")
}

model Referral {
  id                   String              @id @default(uuid()) @db.Uuid
  employerId           String              @map("employer_id") @db.Uuid
  clientId             String              @map("client_id") @db.Uuid
  counsellingRequestId String?             @unique @map("counselling_request_id") @db.Uuid
  serviceType          ServiceType         @map("service_type")
  urgency              UrgencyLevel        @default(ROUTINE)
  status               ReferralStatus      @default(SUBMITTED)
  notes                String?
  rejectionReason      String?             @map("rejection_reason")
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  employer             Employer            @relation("ReferralEmployer", fields: [employerId], references: [userId], onDelete: Cascade)
  client               Client              @relation("ReferralClient", fields: [clientId], references: [userId], onDelete: Cascade)
  counsellingRequest   CounsellingRequest? @relation(fields: [counsellingRequestId], references: [id], onDelete: SetNull)

  @@index([employerId, createdAt])
  @@index([status, createdAt])
  @@map("referrals")
}
